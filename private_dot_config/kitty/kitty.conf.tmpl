# ==========================================
# Font Settings
# ==========================================
font_family      PixelMplus12
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        12.0

# Nerd Font symbol mapping
# For Powerline symbols and other Nerd Font icons
symbol_map U+E0A0-U+E0A3,U+E0B0-U+E0BF,U+E0C0-U+E0C7,U+E0CC-U+E0CF,U+E0D0-U+E0D4 SauceCodePro Nerd Font

# ==========================================
# Color Scheme
# ==========================================
# include ./themes/default.conf

# ==========================================
# Background Image
# ==========================================
background_image wallpapers/c_1.png
# background_image wallpapers/m_1.png
background_image_layout scaled
{{ if eq .chezmoi.os "darwin" }}
background_tint 0.98
{{ else}}
background_tint 0.9
{{ end }}

# ==========================================
# Tab Bar Settings
# ==========================================
tab_bar_edge top
tab_bar_style powerline
tab_powerline_style slanted
tab_title_template "{index}: {title}"

# ==========================================
# Window Settings
# ==========================================
window_padding_width 4
confirm_os_window_close 1

# ==========================================
# Key Bindings
# ==========================================

# Split panes
map cmd+d launch --location=hsplit --cwd=current
map cmd+shift+d launch --location=vsplit --cwd=current

# Move between panes
map cmd+shift+h neighboring_window left
map cmd+shift+j neighboring_window down
map cmd+shift+k neighboring_window up
map cmd+shift+l neighboring_window right

# Cycle panes (previous/next)
map cmd+[ previous_window
map cmd+] next_window

# Close pane
map cmd+w close_window_with_confirmation

# Tab switching (override default pane movement)
map cmd+1 goto_tab 1
map cmd+2 goto_tab 2
map cmd+3 goto_tab 3
map cmd+4 goto_tab 4
map cmd+5 goto_tab 5
map cmd+6 goto_tab 6
map cmd+7 goto_tab 7
map cmd+8 goto_tab 8
map cmd+9 goto_tab 9

# Move tab
map cmd+shift+[ move_tab_backward
map cmd+shift+] move_tab_forward

map shift+enter send_text all \x1b[200~\n\x1b[201~
